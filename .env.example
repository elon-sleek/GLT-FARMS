# ── Server ────────────────────────────────────────────────────────
PORT=3000

# Public URL of the deployed app (used in admin confirmation emails)
# For local dev you can leave this as http://localhost:3000
BASE_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────────
# If SMTP_HOST is not set, emails are logged to the console instead.

# SMTP server hostname, e.g. smtp.gmail.com or smtp.mail.yahoo.com
SMTP_HOST=smtp.example.com

# SMTP port: 587 (STARTTLS, most common) or 465 (SSL)
SMTP_PORT=587

# Set to "true" if using port 465
SMTP_SECURE=false

# SMTP login credentials
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password

# The "From" address shown in sent emails (defaults to SMTP_USER if blank)
SMTP_FROM=GLT Farms <your-email@example.com>

# ── Admin email (who receives payment-submitted notifications) ─────
# Defaults to akinyanwola@yahoo.com if not set
ADMIN_EMAIL=akinyanwola@yahoo.com
